// PUT /api/users/:id — Update a user completely
// PATCH /api/users/:id — Update a user partially
 
// Most APIs use PUT for full update and PATCH for partial update
// In practice PATCH is more commonly used because you only send
// the fields you want to change
 
router.patch("/:id", async (req, res) => {
    try {
        // findByIdAndUpdate — find by ID and update in one step
        const user = await User.findByIdAndUpdate(
            req.params.id,    // which document to update
            req.body,         // what to update it with
            {
                new: true,        // return the UPDATED document, not the old one
                runValidators: true  // run schema validation on the new data
            }
        );
 
        if (!user) {
            return res.status(404).json({
                message: "User not found"
            });
        }
 
        res.status(200).json({
            message: "User updated successfully",
            user: user
        });
 
    } catch (error) {
        res.status(400).json({
            message: "Failed to update user",
            error: error.message
        });
    }
});
 
